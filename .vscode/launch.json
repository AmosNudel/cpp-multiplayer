{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Client",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/game_client.exe",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [
                { "name": "SERVER_HOST", "value": "127.0.0.1" },
                { "name": "SERVER_PORT", "value": "7777" }
            ],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "C:/raylib/w64devkit/bin/gdb.exe",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "cmake: build debug"
        },
        {
            "name": "Run Client",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/game_client.exe",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [
                { "name": "SERVER_HOST", "value": "127.0.0.1" },
                { "name": "SERVER_PORT", "value": "7777" }
            ],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "C:/raylib/w64devkit/bin/gdb.exe",
            "preLaunchTask": "cmake: build release"
        },
        {
            "name": "Debug Server",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/game_server.exe",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [
                { "name": "TCP_PORT", "value": "7777" },
                { "name": "WS_PORT", "value": "7778" }
            ],
            "externalConsole": true,
            "MIMode": "gdb",
            "miDebuggerPath": "C:/raylib/w64devkit/bin/gdb.exe",
            "preLaunchTask": "cmake: build server"
        }
    ]
}
