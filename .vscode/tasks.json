{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "cmake: build debug",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-ExecutionPolicy", "Bypass",
                "-File", "${workspaceFolder}/tools/build.ps1",
                "-Config", "Debug"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "cmake: build release",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-ExecutionPolicy", "Bypass",
                "-File", "${workspaceFolder}/tools/build.ps1",
                "-Config", "Release"
            ],
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "cmake: build server",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-ExecutionPolicy", "Bypass",
                "-File", "${workspaceFolder}/tools/build.ps1",
                "-Config", "Release",
                "-ServerOnly"
            ],
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "build installer",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-ExecutionPolicy", "Bypass",
                "-File", "${workspaceFolder}/tools/build_installer.ps1"
            ],
            "problemMatcher": []
        },
        {
            "label": "build web",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-ExecutionPolicy", "Bypass",
                "-File", "${workspaceFolder}/tools/build_web.ps1"
            ],
            "problemMatcher": ["$gcc"]
        }
    ]
}
