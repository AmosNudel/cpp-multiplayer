# Copy this file to production.env.ps1 and fill in your Railway endpoints.
# production.env.ps1 is gitignored — safe to put real host/port values there.
#
#   copy config\production.env.ps1.example config\production.env.ps1

$ProductionServerHost = "your-tcp-proxy.rlwy.net"
$ProductionServerPort = "00000"
$ProductionWsHost     = "your-app.up.railway.app"
# Optional: only for local ws:// dev builds (-WsPort). Production wss uses port 443.
# $ProductionWsPort     = "7778"
